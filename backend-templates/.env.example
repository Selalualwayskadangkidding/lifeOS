APP_NAME=LifeOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Must match the frontend's own origin exactly — Sanctum SPA cookie auth (§6, §18)
# depends on this being correct.
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Supabase Postgres — architecture §5/§6: Supabase used purely as a managed
# Postgres host, no Supabase Auth, no RLS. Use the *direct* connection string
# (not the pooled one) unless you've confirmed Laravel's persistent-connection
# behavior against Supabase's pooler docs (Sprint 1.2 risk note).
DB_CONNECTION=pgsql
DB_HOST=REPLACE_WITH_SUPABASE_HOST
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=REPLACE_WITH_SUPABASE_USER
DB_PASSWORD=REPLACE_WITH_SUPABASE_PASSWORD
# Supabase Postgres requires SSL — see Sprint 1.2 risk note.
DB_SSLMODE=require

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false

CACHE_STORE=file
QUEUE_CONNECTION=sync
